#: ../../source/api/actor_sensor.md:8
msgid "Sensor"
msgstr ""

#: miniworlds.actors.sensors.sensor_actor.Sensor:1 of
msgid "An invisible sensor attached to another actor."
msgstr ""

#: miniworlds.actors.sensors.sensor_actor.Sensor:3 of
msgid ""
"A ``Sensor`` follows the actor it is attached to and detects nearby "
"objects. The sensor itself is not visible and will never detect the actor"
" it belongs to."
msgstr ""

#: miniworlds.actors.sensors.sensor_actor.Sensor:7 of
msgid "Use ``actor.register_sensor(Sensor)`` to attach a sensor to an actor."
msgstr ""

