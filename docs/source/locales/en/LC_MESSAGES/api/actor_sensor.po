#: ../../source/api/actor_sensor.md:16
msgid "Circle Sensor"
msgstr ""

#: miniworlds.actors.sensors.circle_sensor.CircleSensor:1 of
msgid "A circular invisible sensor attached to another actor."
msgstr ""

#: miniworlds.actors.sensors.circle_sensor.CircleSensor:3 of
msgid ""
"``CircleSensor`` creates a circle of a given *distance* (radius) around "
"the parent actor. Any actor that overlaps with this circle will be "
"detected. The sensor itself is invisible and never detects the parent "
"actor."
msgstr ""

#: miniworlds.actors.sensors.circle_sensor.CircleSensor:8 of
msgid "Use ``actor.register_sensor(CircleSensor, distance=<pixels>)`` to attach."
msgstr ""

#: miniworlds.actors.sensors.circle_sensor.CircleSensor:10 of
msgid "The parent actor this sensor belongs to."
msgstr ""

#: miniworlds.actors.sensors.circle_sensor.CircleSensor:11 of
msgid "Radius of the circular detection area in pixels."
msgstr ""

