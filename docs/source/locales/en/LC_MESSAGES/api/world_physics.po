"\\`\\~miniworlds.actors.shapes.shapes.Line\\``"
msgstr ""

#: miniworlds_physics.physics_world.PhysicsWorld.damping:1 of
msgid "Amount of simple damping to apply to the space."
msgstr ""

#: miniworlds_physics.physics_world.PhysicsWorld.damping:3 of
#, python-format
msgid ""
"A value of 0.9 means that each body will lose 10% of its velocity per "
"second. Defaults to 1."
msgstr ""

