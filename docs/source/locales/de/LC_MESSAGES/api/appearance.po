#: miniworlds.appearances.appearance.Appearance.draw_color_on_image:1 of
msgid "Queue drawing a colored rectangle onto the appearance image."
msgstr ""
"Plant das Zeichnen eines farbigen Rechtecks auf das Appearance-Bild ein."

#: miniworlds.appearances.appearance.Appearance.draw_image_append:1 of
msgid "Append a pre-rendered surface draw command."
msgstr "Hängt einen Zeichenbefehl für eine vorgerenderte Surface an."

#: miniworlds.appearances.appearance.Appearance.draw_image_set:1 of
msgid "Replace image draw commands with one surface draw command."
msgstr ""
"Ersetzt Bild-Zeichenbefehle durch einen einzelnen Surface-Zeichenbefehl."

#: miniworlds.appearances.appearance.Appearance.draw_on_image:1 of
msgid "Queue drawing an image file onto the appearance image."
msgstr "Plant das Zeichnen einer Bilddatei auf das Appearance-Bild ein."

#: miniworlds.appearances.appearance.Appearance.draw_shape_append:1 of
msgid "Append a shape draw command to the render queue."
msgstr "Hängt einen Form-Zeichenbefehl an die Render-Warteschlange an."

#: miniworlds.appearances.appearance.Appearance.draw_shape_set:1 of
msgid "Replace shape draw commands with a single command."
msgstr "Ersetzt Form-Zeichenbefehle durch einen einzelnen Befehl."

#: miniworlds.appearances.appearance.Appearance.fill:1 of
msgid "Set default fill color for borders and lines"
msgstr "Setzt die Standard-Füllfarbe für Rahmen und Linien."

#: miniworlds.appearances.appearance.Appearance.fill_color:1 of
msgid "Primary fill color for shape-based rendering."
msgstr "Primäre Füllfarbe für formbasiertes Rendering."

#: miniworlds.appearances.appearance.Appearance.flip:1 of
msgid "Convenience wrapper to set `is_flipped`."
msgstr "Hilfsmethode zum Setzen von `is_flipped`."

#: miniworlds.appearances.appearance.Appearance.font_size:1 of
msgid "Current font size used for text rendering."
msgstr "Aktuelle Schriftgröße für das Rendern von Text."

#: miniworlds.appearances.appearance.Appearance.from_array:1 of
msgid "Replace the appearance image from a color array."
msgstr "Ersetzt das Bild der Darstellung durch ein Farbarray."

#: miniworlds.appearances.appearance.Appearance.from_array:3 of
msgid "NumPy color array, usually created with `to_colors_array()`."
msgstr "NumPy-Farbarray, üblicherweise mit `to_colors_array()` erstellt."

#: miniworlds.appearances.appearance.Appearance.get_color:1 of
msgid "Return the color at a local pixel position."
msgstr "Gibt die Farbe an einer lokalen Pixelposition zurück."

#: miniworlds.appearances.appearance.Appearance.get_image:1 of
msgid ""
"If dirty, the image will be reloaded. The image pipeline will be  processed, "
"defined by \"set_dirty\""
msgstr ""
"Wenn verschmutzt, wird das Bild neu geladen. Die Bildpipeline wird "
"verarbeitet, definiert durch \"set_dirty\""

